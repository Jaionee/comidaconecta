{"type":"route","meta":{"status":200,"headers":{"cache-control":"public, max-age=0, must-revalidate","content-type":"image/svg+xml","x-next-cache-tags":"_N_T_/layout,_N_T_/icon.svg/layout,_N_T_/icon.svg/route,_N_T_/icon.svg"}},"body":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 500 500\" width=\"500\" height=\"500\">\n  <!-- Left figure green -->\n  <circle cx=\"140\" cy=\"150\" r=\"22\" fill=\"#2F8F2F\"/>\n  <path d=\"M140 172 C 85 200, 70 280, 90 345 C 110 385, 165 395, 235 378\" stroke=\"#2F8F2F\" stroke-width=\"26\" fill=\"none\" stroke-linecap=\"round\"/>\n  <!-- Right figure orange -->\n  <circle cx=\"360\" cy=\"150\" r=\"22\" fill=\"#FF8800\"/>\n  <path d=\"M360 172 C 415 200, 430 280, 410 345 C 390 385, 335 395, 265 378\" stroke=\"#FF8800\" stroke-width=\"26\" fill=\"none\" stroke-linecap=\"round\"/>\n  <!-- Bowl -->\n  <path d=\"M195 280 L195 325 C195 370, 305 370, 305 325 L305 280\" stroke=\"#2F8F2F\" stroke-width=\"10\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M188 280 L312 280\" stroke=\"#2F8F2F\" stroke-width=\"10\" fill=\"none\" stroke-linecap=\"round\"/>\n  <!-- Bread -->\n  <rect x=\"214\" y=\"295\" width=\"40\" height=\"28\" rx=\"6\" fill=\"#FF8800\"/>\n  <line x1=\"222\" y1=\"308\" x2=\"246\" y2=\"308\" stroke=\"#E07000\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n  <!-- Fruit -->\n  <circle cx=\"268\" cy=\"308\" r=\"14\" fill=\"#FF6600\"/>\n  <path d=\"M268 294 C 272 288, 280 288, 278 296\" fill=\"#2F8F2F\"/>\n  <!-- Leaves -->\n  <path d=\"M240 316 C 226 312, 220 322, 230 330 C 224 338, 232 348, 242 340\" fill=\"#2F8F2F\" opacity=\"0.8\"/>\n  <path d=\"M242 318 C 248 308, 260 312, 255 325\" fill=\"#2F8F2F\" opacity=\"0.7\"/>\n  <path d=\"M240 318 C 238 330, 242 340, 250 345\" stroke=\"#2F8F2F\" stroke-width=\"3\" fill=\"none\" stroke-linecap=\"round\"/>\n</svg>\n"}