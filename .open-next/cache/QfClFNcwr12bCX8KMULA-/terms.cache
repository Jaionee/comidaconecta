e podrá existir una contribución voluntaria o plan de mantenimiento, siempre avisado previamente.\"]}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold text-zinc-100 mb-3\",\"children\":\"6. Protección de datos\"}],[\"$\",\"p\",null,{\"children\":\"Los datos personales se tratan conforme al Reglamento General de Protección de Datos (RGPD). Puedes solicitar la eliminación de tu cuenta y datos en cualquier momento contactando con nosotros.\"}]]}]]}]]}]}],[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/02ano3d0-_59t.js\",\"async\":true}]],[\"$\",\"$L4\",null,{\"children\":[\"$\",\"$5\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@6\"}]}]]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"QfClFNcwr12bCX8KMULA-\"}\n6:null\n","/terms":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/0s1qbjflqyc99.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/1eb1kj6j4h1db.js\"],\"default\"]\n3:I[37457,[\"/_next/static/chunks/0s1qbjflqyc99.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/1eb1kj6j4h1db.js\"],\"default\"]\n4:[]\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L3\",null,{}]}]]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":\"$W4\",\"buildId\":\"QfClFNcwr12bCX8KMULA-\"}\n","/_index":"1:\"$Sreact.fragment\"\n2:I[72849,[\"/_next/static/chunks/0s1qbjflqyc99.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/1eb1kj6j4h1db.js\"],\"I18nProvider\"]\n3:I[39756,[\"/_next/static/chunks/0s1qbjflqyc99.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/1eb1kj6j4h1db.js\"],\"default\"]\n4:I[37457,[\"/_next/static/chunks/0s1qbjflqyc99.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/1eb1kj6j4h1db.js\"],\"default\"]\n5:I[58503,[\"/_next/static/chunks/0s1qbjflqyc99.js\",\"/_next/static/chunks/